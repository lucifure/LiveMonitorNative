<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111B21"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Monitor"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#E9EDEF"
            android:paddingStart="12dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="13sp"
        android:textColor="#00A884"
        android:paddingBottom="12dp"/>

    <EditText
        android:id="@+id/urlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste YouTube channel URL..."
        android:textColor="#E9EDEF"
        android:textSize="14sp"
        android:background="@drawable/input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:inputType="textUri"
        android:singleLine="true"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Start Monitoring"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#00A884"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Stop"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#FF5252"
            android:enabled="false"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ACTIVITY LOG"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#667781"
        android:letterSpacing="0.1"
        android:paddingBottom="6dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/log_bg">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#8696A0"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:lineSpacingExtra="4dp"/>

    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saves to: Download/YouTubeMonitor/"
        android:textSize="10sp"
        android:textColor="#3D5263"
        android:paddingTop="8dp"/>

</LinearLayout>
